{
  "name": "midnight-kitties",
  "license": "GPL-3.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/api/*",
    "packages/contracts/*"
  ],
  "scripts": {
    "compact": "turbo run compact --filter=@midnight-ntwrk/kitties-contract",
    "build": "turbo run build",
    "build:contracts": "turbo run build --filter=@midnight-ntwrk/kitties-contract",
    "build:api": "turbo run build --filter=@repo/kitties-api",
    "build:ui": "turbo run build --filter=@repo/ui",
    "build:app": "turbo run build --filter=@repo/web-app",
    "start": "turbo run start --filter=@repo/web-app",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "test-api": "turbo run test-api --filter=@repo/kitties-api",
    "test-contract": "turbo run test --filter=@midnight-ntwrk/kitties-contract"
  },
  "dependencies": {
    "@eslint/js": "^9.28.0",
    "@midnight-ntwrk/compact-runtime": "^0.8.1",
    "@midnight-ntwrk/dapp-connector-api": "^3.0.0",
    "@midnight-ntwrk/ledger": "^4.0.0",
    "@midnight-ntwrk/midnight-js-contracts": "2.0.2",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "2.0.2",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "2.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "2.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "2.0.2",
    "@midnight-ntwrk/midnight-js-types": "2.0.2",
    "@midnight-ntwrk/midnight-js-utils": "2.0.2",
    "@midnight-ntwrk/wallet": "5.0.0",
    "@midnight-ntwrk/wallet-api": "5.0.0",
    "@midnight-ntwrk/zswap": "^4.0.0",
    "@types/node": "^22.15.29",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "rxjs": "^7.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0",
    "midnight-contracts": "git+https://riusricardo@github.com/riusricardo/midnight-contracts"
  },
  "devDependencies": {
    "eslint": "^9.28.0",
    "http-server": "^14.1.1",
    "prettier": "^3.2.5",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-wasm": "^3.4.1",
    "vitest": "^3.2.0"
  },
  "packageManager": "yarn@1.22.22"
}
